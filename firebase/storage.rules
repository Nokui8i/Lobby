rules_version = '2';

service firebase.storage {
  match /b/{bucket}/o {
    function signedIn() {
      return request.auth != null;
    }

    function staffRoleOnUserProfile() {
      return firestore.exists(/databases/(default)/documents/users/$(request.auth.uid))
        && firestore.get(/databases/(default)/documents/users/$(request.auth.uid)).data.staffRole
          in ['moderator', 'admin', 'owner'];
    }

    function isStaff() {
      return signedIn() && (
        request.auth.token.staffRole in ['moderator', 'admin', 'owner']
        || staffRoleOnUserProfile()
      );
    }

    function isListingMedia() {
      return request.resource.contentType.matches('image/.*') ||
        request.resource.contentType.matches('video/.*');
    }

    function isBannerImage() {
      return request.resource.contentType.matches('image/.*')
        && request.resource.size < 15 * 1024 * 1024;
    }

    match /listing-media/{userId}/{listingId}/{fileName} {
      allow read: if true;
      allow create, update: if signedIn() && request.auth.uid == userId && isListingMedia();
      allow delete: if signedIn() && request.auth.uid == userId;
    }

    match /chat-media/{threadId}/{fileName} {
      allow read, write: if signedIn();
    }

    match /home-banners/{fileName} {
      allow read: if true;
      allow create, update: if isStaff() && isBannerImage();
      allow delete: if isStaff();
    }

    match /listing-banners/{fileName} {
      allow read: if true;
      allow create, update: if isStaff() && isBannerImage();
      allow delete: if isStaff();
    }
  }
}
