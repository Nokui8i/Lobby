rules_version = '2';

service firebase.storage {
  match /b/{bucket}/o {
    function signedIn() {
      return request.auth != null;
    }

    function isListingMedia() {
      return request.resource.contentType.matches('image/.*') ||
        request.resource.contentType.matches('video/.*');
    }

    match /listing-media/{userId}/{listingId}/{fileName} {
      allow read: if true;
      allow create, update: if signedIn() && request.auth.uid == userId && isListingMedia();
      allow delete: if signedIn() && request.auth.uid == userId;
    }

    match /chat-media/{threadId}/{fileName} {
      allow read, write: if signedIn();
    }
  }
}
