# לובי (Lobby) — מובייל (Expo)
# ============================================
# אם הריפו ציבורי: העתיקו רק ל־.env.local והחזירו כאן placeholders — לא לדחוף מפתחות ל־Git.
# 1. שמור עותק של הקובץ הזה בשם:  .env.local  (באותה תיקייה: apps/mobile/)
# 2. Expo טוען אוטומטית משתנים עם קידומת EXPO_PUBLIC_ מ־.env ומ־.env.local
# 3. הערכים למטה תואמים ל־firebaseConfig של אפליקציית ה־Web בפרויקט Firebase שלך

# --- Firebase (אותו אובייקט כמו ב־initializeApp) ---
EXPO_PUBLIC_FIREBASE_API_KEY=AIzaSyDBjMH_lIzTgmGSyi9IhkpsNxFGAAgek_8
EXPO_PUBLIC_FIREBASE_AUTH_DOMAIN=lobby-rental-platform.firebaseapp.com
EXPO_PUBLIC_FIREBASE_PROJECT_ID=lobby-rental-platform
EXPO_PUBLIC_FIREBASE_STORAGE_BUCKET=lobby-rental-platform.firebasestorage.app
EXPO_PUBLIC_FIREBASE_MESSAGING_SENDER_ID=236687073343
EXPO_PUBLIC_FIREBASE_APP_ID=1:236687073343:web:226bcb04ec663c8f55d88a

# --- Google Sign-In במובייל (חובה לכפתור "המשך עם Google") ---
# זה *לא* apiKey למעלה. זה OAuth "Web client" — מחרוזת שמסתיימת ב־.apps.googleusercontent.com
# מקורות: Firebase → Authentication → Google | Google Cloud → Credentials → OAuth Web client
# או: מ־google-services.json (אחרי firebase apps:sdkconfig ANDROID) — בתוך oauth_client הרשומה עם "client_type": 3
EXPO_PUBLIC_GOOGLE_WEB_CLIENT_ID=

# ברירת מחדל: active. לטיוטה בלבד: EXPO_PUBLIC_LOBBY_STRICT_DRAFT_PUBLISH=true
# EXPO_PUBLIC_LOBBY_STRICT_DRAFT_PUBLISH=

# Expo Push (projectId מ־app.json → extra.eas או מ־expo.dev)
EXPO_PUBLIC_EAS_PROJECT_ID=

# חיפוש כתובות (Google Places): המפתח מוגדר רק ב-Cloud Functions — ראו firebase/functions/.env.example
