# העתק ל־.env.local — אותם ערכי Firebase כמו apps/web

NEXT_PUBLIC_FIREBASE_API_KEY=
NEXT_PUBLIC_FIREBASE_AUTH_DOMAIN=lobby-rental-platform.firebaseapp.com
NEXT_PUBLIC_FIREBASE_PROJECT_ID=lobby-rental-platform
NEXT_PUBLIC_FIREBASE_STORAGE_BUCKET=lobby-rental-platform.firebasestorage.app
NEXT_PUBLIC_FIREBASE_MESSAGING_SENDER_ID=
NEXT_PUBLIC_FIREBASE_APP_ID=

# פיתוח בלבד (אופציונלי) — UID של owner עד להגדרת Custom Claim
# NEXT_PUBLIC_LOBBY_DEV_OWNER_UIDS=your-firebase-uid

# קישור «צפייה במודעה» מעמוד דיווחים (אתר צרכני)
# NEXT_PUBLIC_LOBBY_WEB_ORIGIN=http://localhost:3000
